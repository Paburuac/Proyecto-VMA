# =============================================
# VMA INDUSTRIAL – Plantilla de variables de entorno
# =============================================
# Copia este archivo como .env y completa los valores.
#   cp .env.example .env
#
# Este archivo SÍ se puede subir a Git (no tiene keys reales).
# El archivo .env NUNCA debe subirse a Git.
# =============================================

# ── Supabase ──────────────────────────────────
# URL del proyecto. Se obtiene en:
#   Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima (safe para el frontend).
# Se obtiene en:
#   Supabase Dashboard → Project Settings → API → Project API Keys → anon / public
#
# ⚠️  NUNCA usar aquí la service_role key — tiene acceso total y bypassea RLS.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Notas ─────────────────────────────────────
# Vite expone al navegador SOLO las variables con prefijo VITE_.
# Si agregas variables sin ese prefijo, NO estarán disponibles en el código.
#
# Si alguna de las dos variables falta, el cliente Supabase fallará al
# inicializar y verás un error en consola del navegador.
