# =============================================
# VMA INDUSTRIAL – .gitignore
# =============================================

# Editores / IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Node (por si se migra a framework en el futuro)
node_modules/
dist/
build/
.env
.env.local
.env.production

# Python (por si se agrega backend)
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Archivos temporales
*.tmp
*.bak
*.swp

# Archivos de datos sensibles
data/usuarios.json
data/tokens.json

# Imágenes grandes / originales sin comprimir
# (descomenta si aplica)
# media/productos/**/*.psd
# media/productos/**/*.ai
